@page "/passwordentries"
@using BlazorPass.Models
@using BlazorPass.Services
@using Microsoft.AspNetCore.SignalR.Client // <-- Добавьте эту строку
@inject PasswordEntryService PasswordEntryService
@inject NavigationManager NavigationManager
@implements IAsyncDisposable // <-- Добавьте эту строку

<h3>Password Entries</h3>

<button class="btn btn-primary" @onclick="NavigateToAddEntry">Add New Entry</button>

@if (passwordEntries == null)
{
    <p><em>Loading...</em></p>
}
else
{
    <table class="table">
        <thead>
            <tr>
                <th>Title</th>
                <th>Username</th>
                <th>Password</th>
                <th>URL</th>
                <th>Notes</th>
                <th>Actions</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var entry in passwordEntries)
            {
                <tr>
                    <td>@entry.Title</td>
                    <td>@entry.Username</td>
                    <td>@entry.Password</td>
                    <td>@entry.Url</td>
                    <td>@entry.Notes</td>
                    <td>
                        <button class="btn btn-info btn-sm" @onclick="(() => NavigateToEditEntry(entry.Id))">Edit</button>
                        <button class="btn btn-danger btn-sm" @onclick="(() => DeleteEntry(entry.Id))">Delete</button>
                    </td>
                </tr>
            }
        </tbody>
    </table>
}

@code {
    private List<PasswordEntry>? passwordEntries;
    private HubConnection? hubConnection; // <-- Добавьте это поле

    protected override async Task OnInitializedAsync()
    {
        // Инициализация соединения с SignalR Hub
        hubConnection = new HubConnectionBuilder()
            .WithUrl(NavigationManager.ToAbsoluteUri("/tableupdatehub")) // URL вашего Hub'а
            .Build();

        // Подписка на метод "ReceiveTableUpdate" от Hub'а
        hubConnection.On<string>("ReceiveTableUpdate", async (message) =>
        {
            Console.WriteLine($"SignalR: {message}");
            await LoadPasswordEntries(); // Перезагружаем данные
            await InvokeAsync(StateHasChanged); // Обновляем UI
        });

        // Опционально: более специфичная подписка, если вы хотите обновлять только измененную запись
        hubConnection.On<int, string>("ReceivePasswordEntryUpdate", async (entryId, action) =>
        {
            Console.WriteLine($"SignalR: Entry {entryId} was {action}.");
            // Здесь можно реализовать более гранулярное обновление,
            // например, найти запись по ID и обновить ее, или удалить из списка.
            // Для простоты пока просто перезагружаем все.
            await LoadPasswordEntries();
            await InvokeAsync(StateHasChanged);
        });


        // Запускаем соединение
        await hubConnection.StartAsync();

        // Изначальная загрузка данных
        await LoadPasswordEntries();
    }

    private async Task LoadPasswordEntries()
    {
        passwordEntries = await PasswordEntryService.GetPasswordEntriesAsync();
    }

    private void NavigateToAddEntry()
    {
        NavigationManager.NavigateTo("/passwordentry/add");
    }

    private void NavigateToEditEntry(int id)
    {
        NavigationManager.NavigateTo($"/passwordentry/edit/{id}");
    }

    private async Task DeleteEntry(int id)
    {
        await PasswordEntryService.DeletePasswordEntryAsync(id);
        // LoadPasswordEntries() будет вызван через SignalR, но можно и здесь для немедленного обновления
        // await LoadPasswordEntries();
    }

    // Метод для освобождения ресурсов SignalR при уничтожении компонента
    public async ValueTask DisposeAsync()
    {
        if (hubConnection is not null)
        {
            await hubConnection.DisposeAsync();
        }
    }
}