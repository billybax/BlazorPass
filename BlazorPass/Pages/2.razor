@page "/your-table-page"
@using Microsoft.AspNetCore.SignalR.Client
@implements IAsyncDisposable // Важно для корректного освобождения ресурсов SignalR

<h3>Таблица с данными</h3>

@if (records == null)
{
    <p><em>Загрузка данных...</em></p>
}
else
{
    <table class="table">
        <thead>
            <tr>
                <th>ID</th>
                <th>Название</th>
                <th>Значение</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var record in records)
            {
                <tr>
                    <td>@record.Id</td>
                    <td>@record.Name</td>
                    <td>@record.Value</td>
                </tr>
            }
        </tbody>
    </table>
}

@code {
    private HubConnection? hubConnection;
    private List<YourRecordModel>? records; // Замените YourRecordModel на вашу модель данных

    protected override async Task OnInitializedAsync()
    {
        // Инициализация соединения с SignalR Hub
        hubConnection = new HubConnectionBuilder()
            .WithUrl(NavigationManager.ToAbsoluteUri("/tableupdatehub")) // URL вашего Hub'а
            .Build();

        // Подписка на метод "ReceiveTableUpdate" от Hub'а
        hubConnection.On<string>("ReceiveTableUpdate", async (message) =>
        {
            Console.WriteLine($"Получено уведомление: {message}");
            await LoadRecords(); // Перезагружаем данные
            await InvokeAsync(StateHasChanged); // Обновляем UI
        });

        // Если вы отправляете конкретные объекты, можно подписаться так:
        // hubConnection.On<YourRecordModel>("ReceiveNewRecord", (newRecord) =>
        // {
        //     records?.Add(newRecord);
        //     InvokeAsync(StateHasChanged);
        // });

        // Запускаем соединение
        await hubConnection.StartAsync();

        // Изначальная загрузка данных
        await LoadRecords();
    }

    private async Task LoadRecords()
    {
        // Здесь должен быть ваш код для получения данных из API или сервиса
        // Например, через HttpClient или вызов сервиса напрямую в Blazor Server
        // Для примера, имитируем загрузку:
        // records = await YourApiService.GetRecordsAsync();
        // Или, если это Blazor Server и сервис доступен:
        // records = await YourDataService.GetAllRecordsAsync();

        // Пример заглушки:
        records = new List<YourRecordModel>
        {
            new YourRecordModel { Id = 1, Name = "Запись 1", Value = "Данные A" },
            new YourRecordModel { Id = 2, Name = "Запись 2", Value = "Данные B" }
        };
        // В реальном приложении здесь будет вызов вашего сервиса для получения актуальных данных из БД.
        // Например: records = await _yourDataService.GetAllRecordsAsync();
    }

    // Метод для освобождения ресурсов SignalR при уничтожении компонента
    public async ValueTask DisposeAsync()
    {
        if (hubConnection is not null)
        {
            await hubConnection.DisposeAsync();
        }
    }

    // Пример вашей модели данных
    public class YourRecordModel
    {
        public int Id { get; set; }
        public string? Name { get; set; }
        public string? Value { get; set; }
    }
}